{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/references.schema.json",
  "title": "Source Reference Registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "git"
  ],
  "properties": {
    "git": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "url",
          "branch"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "url": {
            "type": "string",
            "minLength": 1
          },
          "branch": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "spreadsheets": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "type",
              "path"
            ],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "type": {
                "const": "file"
              },
              "path": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "type",
              "url",
              "export"
            ],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "type": {
                "const": "google"
              },
              "url": {
                "type": "string",
                "minLength": 1
              },
              "export": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        ]
      }
    },
    "rfp": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "path"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "jira": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "instance",
        "projects"
      ],
      "properties": {
        "instance": {
          "type": "string",
          "minLength": 1
        },
        "projects": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
